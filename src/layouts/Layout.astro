---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import CanvasBackground from '../components/CanvasBackground.astro';

interface Props {
	title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang as any);

const pageTitle = title || t('site.title');
const pageDesc = description || t('site.description');

// Support per l'arabo RTL
const dir = lang === 'ar' ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={pageDesc} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0a0a0a" />
		<title>{pageTitle}</title>
    <style is:global>
      /* Stili base ispirati al vecchio index.html ma resi robusti per il layout documentale */
      :root {
        --bg-color: #0a0a0a;
        --text-color: #e5e5e5;
        --accent: #ff4500;
      }
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        user-select: none; /* Make text uncopyable */
      }
      main {
        flex: 1;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1rem;
        pointer-events: none; /* Let clicks pass through empty space to canvas */
      }
      /* Re-enable pointer events for interactive/content elements */
      header, .card, .intelligence-panel, .tools-grid, a, button, select, p, h1, h2, h3, h4, li {
        pointer-events: auto;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      header {
        padding: 1rem;
        border-bottom: 1px solid #333;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .lang-switcher {
        display: flex;
        gap: 0.5rem;
      }
    </style>
	</head>
	<body>
    <header>
      <div class="header-left">
        <h1><a href={`/${lang === 'en' ? '' : lang + '/'}`}>{pageTitle}</a></h1>
        <nav class="main-nav">
          <a href={`/${lang === 'en' ? '' : lang + '/'}`}>{t('nav.home')}</a>
          <a href={`/${lang === 'en' ? 'tools' : lang + '/tools'}`}>{t('nav.tools')}</a>
        </nav>
      </div>
      <nav class="lang-switcher">
        <select id="lang-select" data-current={lang}>
          <option value="en">English</option>
          <option value="zh">中文</option>
          <option value="ru">Русский</option>
          <option value="fa">فارسی</option>
          <option value="ar">العربية</option>
          <option value="es">Español</option>
          <option value="it">Italiano</option>
          <option value="pt-br">Português (BR)</option>
          <option value="fr">Français</option>
          <option value="hi">हिन्दी</option>
          <option value="tr">Türkçe</option>
          <option value="id">Bahasa Indonesia</option>
        </select>
      </nav>
    </header>
		<main>
			<slot />
		</main>
    <CanvasBackground />
    <script>
      // Gestione cambio lingua mantenendo il percorso corrente
      const langSelect = document.getElementById('lang-select');
      if (langSelect) {
        langSelect.value = langSelect.getAttribute('data-current');
        langSelect.addEventListener('change', (e) => {
          const newLang = e.target.value;
          const currentPath = window.location.pathname;
          const segments = currentPath.split('/').filter(Boolean);
          const langs = ['en', 'zh', 'ru', 'fa', 'ar', 'es', 'it', 'pt-br', 'fr', 'hi', 'tr', 'id'];
          
          let pathWithoutLang = currentPath;
          if (segments.length > 0 && langs.includes(segments[0])) {
            segments.shift();
            pathWithoutLang = '/' + segments.join('/');
          }
          if (!pathWithoutLang.startsWith('/')) pathWithoutLang = '/' + pathWithoutLang;
          
          window.location.href = newLang === 'en' ? pathWithoutLang : '/' + newLang + (pathWithoutLang === '/' ? '' : pathWithoutLang);
        });
      }

      // Semplice registrazione Service Worker per PWA Offline
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(error => {
            console.error('ServiceWorker registration failed:', error);
          });
        });
      }
    </script>
	</body>
</html>

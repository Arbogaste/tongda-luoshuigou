---
import Layout from '../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import ResiScore from '../components/ResiScore.astro';
import MirrorButton from '../components/MirrorButton.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang as any);
---

<Layout>
  <section class="hero">
    <h2 class="title-logo">痛打落水狗</h2>
    <p class="quote">
      <em>{t('hero.quote')}</em>
    </p>
    <p class="welcome">
      {t('hero.welcome')}
    </p>
    <MirrorButton />
  </section>

  <section class="features">
    <div class="card">
      <h3>{t('feature1.title')}</h3>
      <p>{t('feature1.desc')}</p>
    </div>
    <div class="card">
      <h3>{t('feature2.title')}</h3>
      <p>{t('feature2.desc')}</p>
    </div>
    <div class="card">
      <h3>{t('feature3.title')}</h3>
      <p>{t('feature3.desc')}</p>
    </div>
  </section>

  <section class="intelligence-panel" style="margin-top: 3rem;">
    <h3 style="text-align: center; color: var(--accent); margin-bottom: 1.5rem;">Live Infrastructure Status</h3>
    <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 1.5rem;">
      <ResiScore countryCode="GLOBAL" storageType="ipfs" censorshipRisk="medium" score={8.2} />
      <ResiScore countryCode="RU" storageType="local" censorshipRisk="high" score={4.5} />
      <ResiScore countryCode="BR" storageType="arweave" censorshipRisk="low" score={9.1} />
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .title-logo {
    font-size: 3.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .hero .quote {
    font-size: 1.2rem;
    color: #a3a3a3;
    max-width: 800px;
    margin: 0 auto 1.5rem;
  }
  .hero .welcome {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #e5e5e5;
    max-width: 800px;
    margin: 0 auto 1rem;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #111;
    border: 1px solid #222;
    padding: 1.5rem;
    border-radius: 8px;
    transition: transform 0.2s;
  }
  .card:hover {
    transform: translateY(-5px);
    border-color: #444;
  }
  .card h3 {
    margin-bottom: 0.5rem;
    color: #fff;
  }
  .card p {
    color: #888;
    line-height: 1.5;
  }
</style>

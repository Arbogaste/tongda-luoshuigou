---
import Layout from '../../layouts/Layout.astro';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  const paths = Object.keys(languages)
    .filter(lang => lang !== 'en') // EN is at root /index.astro
    .map((lang) => ({ params: { lang } }));
  return paths;
}

const { lang } = Astro.params;
---

<Layout>
  <section class="hero">
    <h2>痛打落水狗</h2>
    <p>
      <em>"beat the dog that has fallen into the water"</em> — show no mercy to systems that are already collapsing.
    </p>
    <p>
      Welcome to the <strong>De-dollarization & Resilience Web App Hub</strong>. 
      (Localized content for <strong>{languages[lang as keyof typeof languages]}</strong> will be loaded here).
    </p>
  </section>

  <section class="features">
    <div class="card">
      <h3>Resilience & Preservation</h3>
      <p>IPFS + Filecoin Onchain Cloud mirroring. Pay once, store forever with Arweave.</p>
    </div>
    <div class="card">
      <h3>De-dollarized Rails</h3>
      <p>x402 Foundation micro-payments, BRICS Pay integration, and Lightning Network zaps.</p>
    </div>
    <div class="card">
      <h3>Emerging Markets UX</h3>
      <p>Low-bandwidth optimized, PWA offline cache, and 11-language native support.</p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }
  .hero h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
  }
  .hero p {
    font-size: 1.2rem;
    color: #a3a3a3;
    max-width: 800px;
    margin: 0 auto 1rem;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #111;
    border: 1px solid #222;
    padding: 1.5rem;
    border-radius: 8px;
    transition: transform 0.2s;
  }
  .card:hover {
    transform: translateY(-5px);
    border-color: #444;
  }
  .card h3 {
    margin-bottom: 0.5rem;
    color: #fff;
  }
  .card p {
    color: #888;
    line-height: 1.5;
  }
</style>

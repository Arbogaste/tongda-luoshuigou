---
---
<div id="wrap">
  <canvas id="c"></canvas>
  <div id="link-layer"></div>
</div>

<script>
  // We use Astro's client-side script bundling
  import './canvas/main';
</script>

<style>
  #wrap {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1; /* Manda il canvas in background */
    pointer-events: none; /* Lascia che i click passino attraverso, eccetto per il link-layer */
  }
  canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
  #link-layer {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: auto; /* Abilita i click sui link renderizzati via JS */
  }
</style>

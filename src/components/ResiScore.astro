---
interface Props {
  countryCode?: string;
  storageType?: 'ipfs' | 'arweave' | 'local';
  censorshipRisk?: 'high' | 'medium' | 'low';
  score?: number;
}

const { 
  countryCode = 'GLOBAL', 
  storageType = 'ipfs', 
  censorshipRisk = 'medium',
  score = 7.5
} = Astro.props;

// Calcola un colore in base allo score (1-10)
const scoreColor = score >= 8 ? '#00ff7f' : score >= 5 ? '#ffaa00' : '#ff4500';
---

<div class="resi-score-widget">
  <div class="score-header">
    <span class="country-badge">{countryCode}</span>
    <h4>ResiScore</h4>
  </div>
  <div class="score-body">
    <div class="score-number" style={`color: ${scoreColor};`}>{score.toFixed(1)}</div>
    <div class="score-details">
      <div class="detail-row">
        <span>Storage:</span>
        <strong class="uppercase">{storageType}</strong>
      </div>
      <div class="detail-row">
        <span>Censorship Risk:</span>
        <strong class={`risk-${censorshipRisk}`}>{censorshipRisk}</strong>
      </div>
    </div>
  </div>
</div>

<style>
  .resi-score-widget {
    background: rgba(10, 10, 10, 0.8);
    border: 1px solid #333;
    border-radius: 8px;
    padding: 1rem;
    font-family: monospace;
    width: 250px;
    backdrop-filter: blur(4px);
    margin: 1rem 0;
  }
  .score-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px dashed #444;
    padding-bottom: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .country-badge {
    background: var(--accent, #ff4500);
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
  }
  .score-header h4 {
    margin: 0;
    color: #e5e5e5;
    font-size: 0.9rem;
    text-transform: uppercase;
  }
  .score-body {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .score-number {
    font-size: 2.5rem;
    font-weight: bold;
  }
  .score-details {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-size: 0.8rem;
    color: #a3a3a3;
  }
  .detail-row {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .uppercase {
    text-transform: uppercase;
  }
  .risk-high { color: #ff4500; }
  .risk-medium { color: #ffaa00; }
  .risk-low { color: #00ff7f; }
</style>
